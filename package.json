{
  "name": "opsblaze",
  "version": "0.1.0",
  "private": false,
  "author": "Jesse Galliers (https://github.com/jagalliers)",
  "license": "Apache-2.0",
  "description": "AI-powered Splunk investigation with narrative analysis, MCP tool calling, and Open WebUI or Claude backends",
  "repository": {
    "type": "git",
    "url": "https://github.com/jagalliers/opsblaze"
  },
  "homepage": "https://github.com/jagalliers/opsblaze",
  "bugs": {
    "url": "https://github.com/jagalliers/opsblaze/issues"
  },
  "keywords": [
    "splunk",
    "investigation",
    "ai",
    "claude",
    "open-webui",
    "openwebui",
    "mcp",
    "spl",
    "siem",
    "observability",
    "narrative",
    "visualization"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "opsblaze": "bin/opsblaze.cjs"
  },
  "files": [
    "bin/",
    "mcp-server/",
    "server/",
    "src/",
    ".claude/skills/",
    "index.html",
    "package.json",
    "tsconfig.json",
    "tsconfig.server.json",
    "tsconfig.mcp.json",
    "tailwind.config.ts",
    "postcss.config.js",
    "vite.config.ts",
    ".env.example",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "preview": "npm run build && npm start",
    "setup": "node bin/setup.cjs",
    "opsblaze": "node bin/opsblaze.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"mcp-server/**/*.ts\"",
    "lint:fix": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"mcp-server/**/*.ts\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.mcp.json --noEmit",
    "postinstall": "node bin/postinstall.cjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.92",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chart.js": "^4.4.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "js-yaml": "^4.1.0",
    "marked": "^17.0.3",
    "openid-client": "^6.8.4",
    "pino": "^10.3.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "styled-components": "^5.3.11",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "jsdom": "^28.1.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@splunk/themes": ">=0.18.0",
    "@splunk/visualization-context": ">=27.0.0",
    "@splunk/visualization-themes": ">=27.0.0",
    "@splunk/visualizations": ">=28.0.0"
  },
  "peerDependenciesMeta": {
    "@splunk/visualizations": {
      "optional": true
    },
    "@splunk/visualization-context": {
      "optional": true
    },
    "@splunk/visualization-themes": {
      "optional": true
    },
    "@splunk/themes": {
      "optional": true
    }
  },
  "overrides": {
    "lodash": "4.18.1",
    "path-to-regexp": "8.4.2"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "~1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0"
  }
}
