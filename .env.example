# =============================================================================
# OpsBlaze environment file (.env)
# =============================================================================
#
# HOW TO USE THIS FILE
# --------------------
# • Copy to .env:  cp .env.example .env
# • Or run:       node bin/setup.cjs   (writes a minimal .env from your answers)
# • Secure it:    chmod 600 .env
# • Validate:     node bin/opsblaze.cjs check
#
# LEGEND (tags in section headers)
# --------------------
#   [REQUIRED]     Server will not start without this (Splunk + one LLM path).
#   [SETUP]        Written by `node bin/setup.cjs` when you run the wizard.
#   [PICK ONE]     Choose one option in the group; leave the others unset/commented.
#   [OPTIONAL]     Sensible defaults exist; uncomment only if you need to change them.
#
# TYPICAL .env ANATOMY (top → bottom)
# -----------------------------------
#   1. Splunk connection          [REQUIRED]  — always present after setup
#   2. Server (port, bind)        [SETUP]     — PORT always; HOST if remote bind
#   3. LLM backend                [PICK ONE]  — Open WebUI XOR Claude (CLI or API key)
#   4. Authentication             [PICK ONE]  — none (open) XOR local XOR OIDC
#   5. Runtime / limits           [OPTIONAL]  — rate limits, timeouts, logging
#   6. MCP / Splunk guardrails    [OPTIONAL]  — query safety, admin break-glass
#   7. Telemetry                  [OPTIONAL]  — Splunk HEC and/or OpenTelemetry
#
# EXAMPLE PROFILES (what a real .env looks like when configured)
# --------------------------------------------------------------
#
# --- A) Local dev (localhost, Claude CLI, no login) ---
#   # Splunk connection
#   SPLUNK_HOST=splunk.corp.example
#   SPLUNK_PORT=8089
#   SPLUNK_SCHEME=https
#   SPLUNK_TOKEN=...
#   SPLUNK_VERIFY_SSL=true
#   # Server
#   PORT=3000
#   # (no HOST → 127.0.0.1 only; no auth vars → open “Local user” mode)
#   # (no LLM vars → use `claude auth login` on the server)
#
# --- B) LAN lab (Open WebUI + local username/password) ---
#   # Splunk connection
#   SPLUNK_HOST=...
#   SPLUNK_PORT=8089
#   SPLUNK_SCHEME=https
#   SPLUNK_TOKEN=...
#   # Server
#   PORT=3000
#   HOST=0.0.0.0
#   # LLM: Open WebUI
#   OPENWEBUI_BASE_URL=https://openwebui.corp.example
#   OPENWEBUI_API_KEY=...
#   OPENWEBUI_MODEL=llama-3.1-70b
#   # Local authentication (copy the shipped template first)
#   #   cp data/local-auth.example.json data/local-auth.json
#   #   chmod 600 data/local-auth.json
#   #   node bin/opsblaze.cjs hash-password 'your-password'  → paste into passwordHash
#   OPSBLAZE_LOCAL_AUTH_FILE=./data/local-auth.json
#   OPSBLAZE_SESSION_SECRET=<openssl rand -base64 32>
#   OPSBLAZE_ADMIN_GROUPS=admins
#   OPSBLAZE_SECURE_COOKIES=false   # required for plain http:// LAN access
#
# --- C) Production (OIDC + reverse proxy + Open WebUI) ---
#   # Splunk connection
#   SPLUNK_HOST=...
#   # Server
#   PORT=3000
#   HOST=127.0.0.1
#   # LLM: Open WebUI
#   OPENWEBUI_BASE_URL=https://openwebui.example.edu
#   OPENWEBUI_API_KEY=...
#   OPENWEBUI_MODEL=...
#   # OIDC authentication
#   OPSBLAZE_OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
#   OPSBLAZE_OIDC_CLIENT_ID=...
#   OPSBLAZE_OIDC_CLIENT_SECRET=...
#   OPSBLAZE_OIDC_REDIRECT_URI=https://opsblaze.example.edu/api/auth/callback
#   OPSBLAZE_PUBLIC_URL=https://opsblaze.example.edu
#   OPSBLAZE_SESSION_SECRET=<openssl rand -base64 32>
#   OPSBLAZE_OIDC_ADMIN_GROUPS=IT-Security
#   OPSBLAZE_TRUST_PROXY=true
#   OPSBLAZE_SECURE_COOKIES=true
#
# =============================================================================


# ── 1. Splunk connection [REQUIRED] ─────────────────────────────────────
# Written by setup. Prefer SPLUNK_TOKEN over username/password.
# If both token and username/password are set, the token wins.

SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_SCHEME=https
# SPLUNK_TOKEN=
# SPLUNK_USERNAME=admin
# SPLUNK_PASSWORD=changeme
# SPLUNK_VERIFY_SSL=false
SPLUNK_TIMEOUT_MS=60000


# ── 2. Server [SETUP + OPTIONAL] ────────────────────────────────────────
# Setup always writes PORT. HOST only if you chose remote bind in the wizard.

PORT=3000
# HOST=127.0.0.1
#   127.0.0.1  = this machine only (default if unset)
#   0.0.0.0    = all interfaces (LAN/internet) — pair with auth or OPSBLAZE_LOCAL_MODE

# OPSBLAZE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# OPSBLAZE_RATE_LIMIT=10
# OPSBLAZE_API_RATE_LIMIT=60
# OPSBLAZE_STREAM_TIMEOUT_MS=300000
# Reuse Splunk MCP stdio per conversation; close after idle ms (default 300000 = 5 min)
# OPSBLAZE_MCP_SESSION_IDLE_MS=300000
# OPSBLAZE_MAX_TURNS=30
# OPSBLAZE_MAX_HISTORY=20
# OPSBLAZE_MAX_MESSAGE_LEN=10000
# OPSBLAZE_DATA_DIR=./data/conversations
# OPSBLAZE_RECORD_DIR=./fixtures
# LOG_LEVEL=info


# ── 3. LLM backend [PICK ONE] ─────────────────────────────────────────
# Option A — Open WebUI (recommended for institutions):
#   Set OPENWEBUI_BASE_URL (+ API key). Claude CLI is NOT required.
#
# Option B — Claude (default when OPENWEBUI_BASE_URL is unset):
#   Use `claude auth login` (no .env LLM vars), OR set ANTHROPIC_API_KEY below.

# --- 3A. Open WebUI ---
# OPENWEBUI_BASE_URL=https://openwebui.example.edu
# OPENWEBUI_API_KEY=
# OPENWEBUI_MODEL=
# OPENWEBUI_CHAT_API_PREFIX=ollama/v1

# --- 3B. Claude (API key path; CLI OAuth needs no vars here) ---
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-6
# CLAUDE_EFFORT=high


# ── 4. Authentication [PICK ONE] ──────────────────────────────────────
# Option A — Open (no login): leave this entire section commented.
#   On localhost only by default. For LAN without login: HOST=0.0.0.0 + OPSBLAZE_LOCAL_MODE=true
#
# Option B — Local username/password: OPSBLAZE_LOCAL_AUTH_FILE (see README).
#   Do NOT set OPSBLAZE_OIDC_ISSUER. Requires OPSBLAZE_SESSION_SECRET.
#
# Option C — OIDC / SSO: OPSBLAZE_OIDC_ISSUER + client + OPSBLAZE_SESSION_SECRET.
#   Do NOT set OPSBLAZE_LOCAL_AUTH_FILE.

# --- 4B. Local authentication ---
# cp data/local-auth.example.json data/local-auth.json && chmod 600 data/local-auth.json
# OPSBLAZE_LOCAL_AUTH_FILE=./data/local-auth.json
# OPSBLAZE_SESSION_SECRET=
# OPSBLAZE_ADMIN_GROUPS=admins
# OPSBLAZE_LOCAL_AUTH_ADMIN_USERS=admin

# --- 4C. OIDC authentication ---
# OPSBLAZE_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# OPSBLAZE_OIDC_CLIENT_ID=
# OPSBLAZE_OIDC_CLIENT_SECRET=
# OPSBLAZE_OIDC_REDIRECT_URI=https://opsblaze.example.edu/api/auth/callback
# OPSBLAZE_PUBLIC_URL=https://opsblaze.example.edu
# OPSBLAZE_OIDC_SCOPES=openid profile email
# OPSBLAZE_OIDC_ADMIN_EMAILS=admin@example.edu
# OPSBLAZE_OIDC_ADMIN_GROUPS=IT-Security,OpsBlaze-Admins
# OPSBLAZE_ADMIN_GROUPS=admins
# OPSBLAZE_OIDC_ALL_USERS_ADMIN=true
# OPSBLAZE_TRUST_PROXY=true
# OPSBLAZE_SECURE_COOKIES=true

# --- 4A. Open lab mode only (no login, NOT for production) ---
# OPSBLAZE_LOCAL_MODE=true


# ── 5. MCP & Splunk guardrails [OPTIONAL] ───────────────────────────────
# MAX_ROW_LIMIT=10000
# SPL_SAFETY_ENABLED=true
# OPSBLAZE_ALLOW_DOCKER_MCP=true
# OPSBLAZE_SPLUNK_GUARD_ADMIN_EXTRA_INDEXES=audit,_internal
# OPSBLAZE_SPLUNK_GUARD_ADMIN_BYPASS_INDEXES=false


# ── 6. Telemetry [OPTIONAL] — not written by setup ─────────────────────
# Splunk HEC: enable only when BOTH URL and token are set.
# SPLUNK_HEC_URL=https://splunk.local:8088
# SPLUNK_HEC_TOKEN=
# SPLUNK_HEC_INDEX=main
# SPLUNK_HEC_SOURCE=opsblaze
# SPLUNK_HEC_SOURCETYPE=opsblaze:agent
# SPLUNK_HEC_VERIFY_SSL=true
# SPLUNK_HEC_BATCH_SIZE=10
# SPLUNK_HEC_FLUSH_MS=5000

# OpenTelemetry: export traces to an OTEL Collector (off by default).
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=opsblaze
