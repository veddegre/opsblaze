# Splunk connection
# Prefer SPLUNK_TOKEN (Bearer auth) over username/password for security.
# Username/password credentials are sent as Base64-encoded Basic auth.
# NOTE: If both SPLUNK_TOKEN and SPLUNK_USERNAME/SPLUNK_PASSWORD are set,
# the token takes precedence. Comment out or remove the one you don't want.
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_SCHEME=https
# SPLUNK_TOKEN=
# SPLUNK_USERNAME=admin
# SPLUNK_PASSWORD=changeme
# SSL verification is ON by default; set to false only for local/self-signed certs
# SPLUNK_VERIFY_SSL=false
SPLUNK_TIMEOUT_MS=60000

# ── LLM backend: Open WebUI (recommended) ───────────────────────────────
# When OPENWEBUI_BASE_URL is set, OpsBlaze uses Open WebUI instead of Claude.
# API key: Open WebUI → Settings → Account
# Model ID: use the id shown in Open WebUI (GET /api/models)
# OPENWEBUI_BASE_URL=https://openwebui.example.edu
# OPENWEBUI_API_KEY=
# OPENWEBUI_MODEL=
# If chat fails with "Something went wrong :/", set the chat API prefix (auto-detected if unset):
# OPENWEBUI_CHAT_API_PREFIX=ollama/v1

# ── LLM backend: Claude (default if OPENWEBUI_BASE_URL is unset) ───────
# Uses Claude CLI OAuth (run `claude auth login`) or an Anthropic API key.
# ANTHROPIC_API_KEY=sk-ant-...

# Model id (Open WebUI model id when using Open WebUI; Claude model otherwise)
# CLAUDE_MODEL=claude-opus-4-6

# Thinking effort: low | medium | high | max (default: high)
# CLAUDE_EFFORT=high

# Log level: fatal | error | warn | info | debug | trace (default: info)
# LOG_LEVEL=info

# Server
PORT=3000
# Bind address: 127.0.0.1 = localhost only (default), 0.0.0.0 = all interfaces
# HOST=127.0.0.1

# CORS: comma-separated allowed origins (defaults shown)
# OPSBLAZE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting: max requests per minute per IP to /api/chat
# OPSBLAZE_RATE_LIMIT=10

# Stream timeout: max SSE duration in ms before aborting agent
# OPSBLAZE_STREAM_TIMEOUT_MS=300000

# Agent max turns per conversation
# OPSBLAZE_MAX_TURNS=30

# Max history exchanges sent to the LLM per request
# OPSBLAZE_MAX_HISTORY=20

# Max message length in characters
# OPSBLAZE_MAX_MESSAGE_LEN=10000

# Conversation persistence: directory for stored conversations
# OPSBLAZE_DATA_DIR=./data/conversations

# SDK message recording: set to a directory path to record SDK message
# streams as JSONL fixtures for replay testing. Unset = no recording.
# OPSBLAZE_RECORD_DIR=./fixtures

# MCP server: max rows returned from Splunk queries (default: 10000)
# MAX_ROW_LIMIT=10000

# MCP server: enable/disable SPL safety validation (default: true)
# Set to false only in trusted environments where query validation is unneeded.
# SPL_SAFETY_ENABLED=true

# ── Telemetry: Splunk HEC ──────────────────────────────────────────────
# Ship agent telemetry (token usage, cost, tool calls) to Splunk via HEC.
# Both SPLUNK_HEC_URL and SPLUNK_HEC_TOKEN must be set to enable.
# SPLUNK_HEC_URL=https://splunk.local:8088
# SPLUNK_HEC_TOKEN=your-hec-token
# SPLUNK_HEC_INDEX=main
# SPLUNK_HEC_SOURCE=opsblaze
# SPLUNK_HEC_SOURCETYPE=opsblaze:agent
# SPLUNK_HEC_VERIFY_SSL=true
# SPLUNK_HEC_BATCH_SIZE=10
# SPLUNK_HEC_FLUSH_MS=5000

# ── Telemetry: OpenTelemetry ───────────────────────────────────────────
# Export traces/spans to an OTEL Collector via OTLP/HTTP.
# Set OTEL_ENABLED=true and configure the endpoint.
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=opsblaze
